###> docker / infrastructure (aligné ApplicationManager) ###
COMPOSE_PROJECT_NAME=am-driver
HOST_IP=127.0.0.1
RECEPTACLE_PORT=18099
AM_DRIVER_SWAGGER_PORT=18098
DATA_PATH=./var/am-driver
USERID=1000
GROUPID=1000
WORKING_DIR=/var/am-driver
PHP_IMAGE=php:8.3-cli
PHP_IMAGE_PULL_POLICY=build
DOCKER_PHP_BUILT_IMAGE=
BUILD_WHEN_INSTALL=false
DOCKER_DEV=false
###< docker / infrastructure ###

###> am-driver (exemples — surcharger dans .env.local) ###
AM_DRIVER_AM_BASE_URL=https://application-manager.example
AM_DRIVER_SOURCE=am-driver-dev
AM_DRIVER_CONSUMPTION_WEBHOOK_TOKEN=change-me
AM_DRIVER_ORCHESTRATION_CALLBACK_TOKEN=change-me
AM_DRIVER_ORCHESTRATION_COMMAND_TOKEN=dev-command-token
AM_DRIVER_OPERATIONAL_STATE_TOKEN=dev-state-token
###< am-driver ###
